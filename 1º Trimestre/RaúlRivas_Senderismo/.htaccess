<IfModule mod_rewrite.c>
    # Activar mod_rewrite si está disponible
    RewriteEngine On

    # Definir la URL personalizada para los errores 404
    ErrorDocument 404 http://localhost/Senderismo/Error/show_error404

    # Asegurarse de que las rutas no apunten a directorios o archivos físicos
    RewriteCond %{SCRIPT_FILENAME} !-d
    RewriteCond %{SCRIPT_FILENAME} !-f

    # Redirigir todas las solicitudes a index.php con parámetros de controlador y acción
    RewriteRule ^([^/]+)/([^/]+)$ index.php?controller=$1&action=$2 [QSA,L]
</IfModule>
